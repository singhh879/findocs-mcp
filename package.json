{
  "name": "findocs-mcp",
  "version": "0.1.0",
  "description": "MCP server for semantic search + grounded Q&A over a financial-docs corpus, backed by Postgres + pgvector, with an eval-loop that fails CI on regression.",
  "type": "module",
  "license": "MIT",
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "findocs-mcp": "./dist/mcp/server.js"
  },
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "tsx src/mcp/server.ts",
    "build": "tsup",
    "start": "node dist/mcp/server.js",
    "migrate": "tsx db/migrate.ts",
    "ingest": "tsx src/cli/ingest.ts",
    "eval": "tsx evals/run.ts",
    "eval:gate": "tsx evals/run.ts --gate",
    "calibrate": "tsx scripts/calibrate.ts",
    "smoke": "tsx scripts/smoke-mcp.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:wait": "tsx db/wait.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "@xenova/transformers": "^2.17.2",
    "postgres": "^3.4.5",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^20.17.0",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
