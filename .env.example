# ---- Database (Postgres + pgvector) ----
# Matches docker-compose.yml defaults.
DATABASE_URL=postgres://findocs:findocs@localhost:5433/findocs

# ---- Embeddings ----
# Provider for query/document embeddings. Default is a local, zero-cost model.
#   local  -> @xenova/transformers (all-MiniLM-L6-v2, 384-dim), no API key
EMBEDDINGS_PROVIDER=local
EMBEDDINGS_MODEL=Xenova/all-MiniLM-L6-v2

# ---- LLM (answer synthesis + faithfulness judge) ----
# Provider-agnostic. Default is zero-cost and needs no secrets.
#   heuristic -> deterministic extractive synthesis + overlap-based groundedness judge (CI default)
#   ollama    -> local Ollama server (free generative synthesis + LLM-as-judge)
LLM_PROVIDER=heuristic
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# ---- Retrieval / refusal gate ----
# answer_question refuses ("not found") when retrieval confidence is below these floors.
SEARCH_TOP_K=5
# Top-1 cosine similarity must clear this to attempt an answer (0..1).
ANSWER_MIN_TOP_SIMILARITY=0.35
# Mean cosine similarity over the retrieved context must clear this too.
ANSWER_MIN_MEAN_SIMILARITY=0.28
